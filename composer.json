{
    "name": "iline/pop-it-mvc",
    "description": "Simple mvc framework",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "ILINE2006",
            "email": "teplotom71@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10.0",
        "illuminate/events": "^10.0",
        "nikic/fast-route": "^2.0@dev",
        "iline/collect": "dev-main"
    },
    "repositories": [
        {
            "type": "path",
            "url": "./collect"
        }
    ],
    "config": {
        "platform-check": false
    },
    "autoload": {
        "psr-4": {
            "Src\\": "core/Src/",
            "": "app/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    }
}
